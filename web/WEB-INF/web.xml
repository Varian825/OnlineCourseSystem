<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="http://java.sun.com/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://java.sun.com/xml/ns/javaee 
         http://java.sun.com/xml/ns/javaee/web-app_3_0.xsd"
         version="3.0">

    <!-- ================= SESSION ================= -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- ================= WELCOME ================= -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>  
    </welcome-file-list>

    <!-- ================= MAIN CONTROLLER ================= -->
    <servlet>
        <servlet-name>MainController</servlet-name>
        <servlet-class>controller.MainController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>MainController</servlet-name>
        <url-pattern>/main</url-pattern>
    </servlet-mapping>
    
   

    <!-- ================= AUTH ================= -->
    <servlet>
        <servlet-name>LoginController</servlet-name>
        <servlet-class>controller.LoginController</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>LogoutController</servlet-name>
        <servlet-class>controller.LogoutController</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>RegisterController</servlet-name>
        <servlet-class>controller.RegisterController</servlet-class>
    </servlet>

    <!-- ================= COURSE ================= -->
    <servlet>
        <servlet-name>CourseController</servlet-name>
        <servlet-class>controller.CourseController</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>CourseDetailController</servlet-name>
        <servlet-class>controller.CourseDetailController</servlet-class>
    </servlet>

    <!-- ================= REGISTRATION ================= -->
    <servlet>
        <servlet-name>RegistrationController</servlet-name>
        <servlet-class>controller.RegistrationController</servlet-class>
    </servlet>
    
     <servlet-mapping>
        <servlet-name>RegisterController</servlet-name>
        <url-pattern>/RegisterController</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MyCourseController</servlet-name>
        <servlet-class>controller.MyCourseController</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>CancelRegistrationController</servlet-name>
        <servlet-class>controller.CancelRegistrationController</servlet-class>
    </servlet>

    <!-- ================= PROFILE ================= -->
    <servlet>
        <servlet-name>UpdateProfileController</servlet-name>
        <servlet-class>controller.UpdateProfileController</servlet-class>
    </servlet>

    <!-- ================= ADMIN ================= -->
    <servlet>
        <servlet-name>AdminUserController</servlet-name>
        <servlet-class>controller.AdminUserController</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>AdminCourseController</servlet-name>
        <servlet-class>controller.AdminCourseController</servlet-class>
    </servlet>

</web-app>